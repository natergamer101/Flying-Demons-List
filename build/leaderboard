                </tr>
            </thead>
            <tbody>
                
                    <tr>
                        <td>
                            
                            
                                <span class="badge rank-1 fs-5">🥇 #1</span>
                            
                        </td>
                        <td>
                            <a href="/user/NaterGamer" class="fw-bold text-decoration-none d-flex align-items-center">
                                
                                    <img src="/static/uploads/channels4_profile.jpg" alt="Profile" class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover;">
                                
                                NaterGamer
                            </a>
                        </td>
                        <td><span class="badge bg-primary fs-6">50 pts</span></td>
                        <td>2</td>
                        <td>
                            
